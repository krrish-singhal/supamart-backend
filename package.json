{
  "name": "supermarket-backend",
  "version": "1.0.0",
  "description": "Node + Express + Firestore backend for the supermarket delivery app (JavaScript only)",
  "type": "commonjs",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
