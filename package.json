    "compression": "1.7.4",
    "cors": "2.8.5",
    "dayjs": "1.11.13",
    "dotenv": "16.4.5",
    "express": "4.19.2",
    "express-rate-limit": "7.4.0",
    "firebase-admin": "12.4.0",
    "helmet": "7.1.0",
    "ioredis": "5.4.1",
    "joi": "17.13.3",
    "jsonwebtoken": "^9.0.3",
    "morgan": "1.10.0",
    "multer": "1.4.5-lts.1",
