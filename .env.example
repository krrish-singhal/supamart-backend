PORT=5000

# JWT signing secret — generate a strong random value for production
# e.g.: openssl rand -base64 48
JWT_SECRET=

# Admin portal login (used only by createAdmin / createAdminUser scripts, not the server)
ADMIN_EMAIL=admin@yourstore.in
ADMIN_PASSWORD=
ADMIN_NAME=MyMart Admin

# Firebase Admin SDK — Console -> Project Settings -> Service Accounts -> Generate new private key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the full key with literal newlines OR keep \n escapes — both work
FIREBASE_PRIVATE_KEY=

# Cloudinary — Dashboard -> Account Details
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=

# Store location + delivery radius
STORE_LATITUDE=
STORE_LONGITUDE=
SERVICE_RADIUS_KM=5

# WhatsApp owner notifications (optional)
WHATSAPP_ENABLED=false
OWNER_PHONE=
